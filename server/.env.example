# ============================================
# PrintRent - Environment Configuration
# ============================================
# Kopyala: cp .env.example .env
# Hostinger panelinden MySQL bilgilerini alın:
#   hPanel > MySQL Databases > Add New User
#   sonra database'e user'ı bağlayın
# ============================================

# ─── MySQL Database ─────────────────────────
# Hostinger'da genellikle:
#   Host: mysql.hostinger.com (veya sunucu IP'si)
#   Kullanıcı: u[ID]_[kullaniciadi]
#   Veritabanı: u[ID]_[dbadi]
DB_HOST=mysql.hostinger.com
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=true

# ─── Server ─────────────────────────────────
# Hostinger Node.js hosting genelde PORT=8080 kullanır
PORT=3001
NODE_ENV=production
# Domain adresiniz (varsa www'li halini de ekleyin):
CORS_ORIGIN=https://printrent.siteniz.com

# ─── SNMP (Ağ Tarama) ──────────────────────
SNMP_COMMUNITY=public
SNMP_TIMEOUT=3000
SNMP_RETRIES=1

# ─── Network Scan ───────────────────────────
SCAN_CONCURRENCY=100
SCAN_TIMEOUT=3000
